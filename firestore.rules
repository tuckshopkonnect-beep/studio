
/**
 * Core Philosophy: This ruleset enforces a hybrid security model. It provides public,
 * read-only access to shared data like the tuckshop menu (/menuItems), while
 * enforcing strict user ownership for all personal data, such as user profiles
 * (/users/{userId}) and their corresponding orders (/users/{userId}/orders).
 *
 * Data Structure: The data is organized into two main top-level collections:
 * - /menuItems: A public collection containing all available food and drink items.
 * - /users: A collection where each user's private data is stored under a
 *   document matching their unique user ID (UID). All user-specific subcollections,
 *   like 'orders', are nested under this path.
 *
 * Key Security Decisions:
 * - Admin-Managed Content: The menu (/menuItems) and inventory data are now managed
 *   by authenticated admins directly from the client. The rules ensure only users
 *   with the 'Admin' role can perform write operations.
 * - Strict Ownership: A user can only access the data tree located under their
 *   own user ID path (/users/{userId}/**). This prevents users from reading or
 *   writing another user's profile information or order history.
 * - No User Listing: To protect user privacy, listing the entire /users
 *   collection is disallowed for non-admins.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the currently authenticated user has the 'Admin' role.
     * It safely reads the user's profile from the /users collection.
     */
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    /**
     * Validates a new order document on creation.
     * Ensures the creator is the owner and the denormalized `userId` field
     * inside the document matches the owner's UID in the path.
     */
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     */
    match /users/{userId} {
      // A user can always get their own document. This is critical to allow the isAdmin() function to work without circular dependencies.
      allow get: if isOwner(userId);
      
      // Only an admin can list all users.
      allow list: if isAdmin();
      
      // Allow creation if it's an admin doing it, OR if it's the very first user creating their own 'Admin' account.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'Admin');
      
      // Update is complex. It must allow:
      // 1. An admin to update anything.
      // 2. A user to fix their own corrupted profile to become an admin for the first time.
      // 3. A user to update their own profile without changing their role.
      allow update: if 
        isAdmin() ||
        (isOwner(userId) && request.resource.data.role == 'Admin' && !('role' in resource.data)) ||
        (isOwner(userId) && request.resource.data.role == resource.data.role);
      
      // Only an admin can delete a user.
      allow delete: if isAdmin();

      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     */
    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }
    
    /**
     * @description Global application settings, only accessible by admins.
     */
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
