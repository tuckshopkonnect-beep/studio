
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // A user is an admin if their user document has the 'Admin' role.
      // This rule allows this function to read any user's profile to check their role.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isParent(childUserId) {
      // A user is a parent of the child if their own document's `childIds` map
      // contains the child's UID as a key. This is a secure and non-recursive check.
      let parentDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
             && 'childIds' in parentDoc
             && childUserId in parentDoc.childIds;
    }
    
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }
    
    function onlyStockIsChanging() {
      // Ensures that only the 'stock' field is being modified in an update.
      let writeFields = request.writeFields;
      return writeFields.size() == 1 && writeFields[0] == 'stock';
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------
    
    match /schools/{schoolId} {
      // Allow public read for the school selection screen.
      allow read: if true;
      // Allow any signed-in user to create, as the super-admin page is protected.
      // Admins can update/delete.
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }


    match /users/{userId} {
      // A user can read their own profile. An admin function needs to read any profile.
      // `get` is safe for `isAdmin()` because it's non-recursive and only returns one document.
      allow get: if isOwner(userId) || isAdmin() || isParent(userId);
      // Only admins can list all users.
      allow list: if isAdmin();
      
      // CREATE: An admin can create any user profile. A user can create their own 'Admin' profile
      // on initial sign-up. A new user document must have a schoolId if being created by an admin.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'Admin');
      
      // UPDATE: An admin can update any user. A user can update their own profile
      // as long as they are not changing their role. This rule now correctly handles
      // updates to other fields (like balance) by checking the role safely.
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.get('role', resource.data.role) == resource.data.role);


      // DELETE: Only an admin can delete a user profile.
      allow delete: if isAdmin();


      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin() || isParent(userId);
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     */
    match /orders/{orderId} {
      allow get, list: if isAdmin();
      // Any signed-in user can create their own order record in this master list.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can modify or delete from this master list.
      allow update, delete: if isAdmin();
    }
    
    /**
     * @description Global application settings.
     */
    match /settings/{settingId} {
      // Allow any authenticated user to read settings. This is safe as the data is
      // non-sensitive and it prevents client-side race conditions on app load.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      // Anyone can view the menu.
      allow get, list: if true;
      // Admins can create and delete menu items.
      allow create, delete: if isAdmin();
      // An admin can update any field. A student can only update the stock
      // field to decrement it (e.g., when placing an order).
      // This rule now handles cases where 'stock' might not exist on the document.
      allow update: if isAdmin() || 
                       (isSignedIn() && 
                        onlyStockIsChanging() && 
                        request.resource.data.stock < (resource.data.stock || 0));

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
