
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // The `exists()` check is removed as it is redundant and may cause evaluation issues.
      // The subsequent `get()` call will safely fail if the document does not exist.
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isParent(childUserId) {
      // A user is a parent of the child if their own document's `childIds` map
      // contains the child's UID as a key. This is a secure and non-recursive check.
      let parentDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
             && 'childIds' in parentDoc
             && childUserId in parentDoc.childIds;
    }
    
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------
    
    match /schools/{schoolId} {
      // Any signed-in user can create a school during registration.
      // Reading is allowed for any signed-in user to check subscription status (future).
      // Only admins can update it.
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      // A user can read their own profile. An admin function needs to read any profile.
      // This is safe because get() is not recursive and only returns a single document.
      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      // CREATE: An admin can create any user profile, or a user can create their own 'Admin' profile.
      // This is intended to allow the very first user to establish themselves as the administrator.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'Admin');
      
      // UPDATE: An admin can update any user. A user can update their own profile
      // as long as they are not changing their role.
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);

      // DELETE: Only an admin can delete a user profile.
      allow delete: if isAdmin();


      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin() || isParent(userId);
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     */
    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global application settings.
     */
    match /settings/{settingId} {
      // Allow any authenticated user to read settings. This is safe as the data is
      // non-sensitive and it prevents client-side race conditions on app load.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      // Anyone can view the menu.
      allow get, list: if true;
      // Only admins can modify the menu.
      allow write: if isAdmin();

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
