
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the currently authenticated user has the 'Admin' role.
     * It safely reads the user's profile from the /users collection.
     * CRITICAL: This uses `exists()` to prevent errors on first-time login
     * when the user document may not have been created yet.
     */
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    /**
     * Validates a new order document on creation.
     * Ensures the creator is the owner and the denormalized `userId` field
     * inside the document matches the owner's UID in the path.
     */
    function isCreatingValidOrder(userId) {
      // Ensure the user is the owner and the payload's userId matches.
      return isOwner(userId) && request.resource.data.userId == userId;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     */
    match /users/{userId} {
      // READ: A user can always get their own document. This is critical for isAdmin() to work.
      // An admin can get any document via the `list` rule.
      allow get: if isOwner(userId);
      allow list: if isAdmin();

      // DELETE: Only an admin can delete a user.
      allow delete: if isAdmin();

      // CREATE: This rule handles the initial creation of any user.
      // It allows an existing admin to create users, and crucially, allows the VERY FIRST
      // user to create their own account if they are setting the role to 'Admin'.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'Admin');

      // UPDATE: This rule handles updates to existing user documents.
      // It allows an admin to update anyone, or a user to update their own profile
      // as long as they are not trying to change their role. It also allows the role
      // to be set for the first time on an existing partial document.
      allow update: if isAdmin() || (isOwner(userId) && (!('role' in resource.data) || request.resource.data.role == resource.data.role));

      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     * Read access is given to any signed-in user to prevent race conditions on initial dashboard load.
     * Write access is restricted to admins.
     */
    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global application settings.
     * Read and write access is restricted to admins.
     */
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      // Anyone can view the menu.
      allow get, list: if true;
      // Only admins can modify the menu.
      allow create, update, delete: if isAdmin();

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
