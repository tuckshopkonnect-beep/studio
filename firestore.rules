
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // This check is safe because the `get` rule for a user's own profile is non-recursive.
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isParent(childUserId) {
      // A user is a parent of the child if their own document's `childIds` map
      // contains the child's UID as a key. This is a secure and non-recursive check.
      let parentDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
             && 'childIds' in parentDoc
             && childUserId in parentDoc.childIds;
    }
    
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    match /users/{userId} {
      // READ:
      // Any authenticated user can get an individual user profile. This is necessary
      // to allow the isAdmin() helper function to read a user's role without causing
      // a recursive loop in the security rules. The more restrictive `list` rule
      // below prevents downloading the entire collection.
      allow get: if isSignedIn();
      
      // LIST:
      // Only admins can list/query the entire users collection.
      allow list: if isAdmin();
      
      // CREATE:
      // An admin can create any user.
      // A new user can create their own 'Admin' profile (for initial setup).
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'Admin');
      
      // UPDATE:
      // An admin can update any user.
      // A user can update their own profile as long as they are not changing their role.
      // This also allows a role to be set for the first time on a partially created document.
      allow update: if isAdmin() || (isOwner(userId) && (!('role' in resource.data) || request.resource.data.role == resource.data.role));

      // DELETE:
      // Only an admin can delete a user profile.
      allow delete: if isAdmin();


      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin() || isParent(userId);
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     */
    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global application settings.
     */
    match /settings/{settingId} {
      // Allow any authenticated user to read settings. This is safe as the data is
      // non-sensitive and it prevents client-side race conditions on app load.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      // Anyone can view the menu.
      allow get, list: if true;
      // Only admins can modify the menu.
      allow write: if isAdmin();

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
