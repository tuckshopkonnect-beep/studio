
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use .get() with a default value to prevent crashes if the 'role' field is missing.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Admin';
    }
    
    function isParent(childUserId) {
      // Safely access parent document data.
      let parentData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
             && parentData.get('childIds', {})[childUserId] == true;
    }
    
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }
    
    function isDecrementingStock() {
      // Ensures only 'stock' is being changed, and it's a decrement.
      let isStockOnly = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']);
      let newStock = request.resource.data.stock;
      let oldStock = resource.data.get('stock', 0);
      
      return isStockOnly && newStock < oldStock && newStock >= 0;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------
    
    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    match /passwordResetRequests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(['userEmail', 'requestDate', 'status'])
                      && request.resource.data.userEmail is string
                      && request.resource.data.status == 'Pending';
      allow read, list, update, delete: if isAdmin();
    }


    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isParent(userId);
      allow list: if isAdmin();
      
      // Allow creation for new admins or by existing admins.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.get('role', '') == 'Admin');
      
      // Allow update if the actor is an admin OR if they are the owner and not changing their role or school.
      allow update: if isAdmin() || (
        isOwner(userId) 
        && request.resource.data.get('role', resource.data.get('role', '')) == resource.data.get('role', '')
        && request.resource.data.get('schoolId', resource.data.get('schoolId', '')) == resource.data.get('schoolId', '')
      );

      allow delete: if isAdmin();

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin() || isParent(userId);
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    match /orders/{orderId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && isDecrementingStock());

      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
