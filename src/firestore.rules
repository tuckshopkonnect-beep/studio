
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // This check is safe because the `get` rule for a user's own profile is non-recursive.
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    match /users/{userId} {
      // READ: A user can read their own profile. Admins can list all users.
      allow get: if isOwner(userId);
      allow list: if isAdmin();
      
      // DELETE: Only an admin can delete a user profile.
      allow delete: if isAdmin();

      // WRITE (CREATE/UPDATE): This is the critical rule for bootstrapping the first admin
      // and managing all other user profile writes.
      allow write: if
        // 1. Admins can write to any user profile.
        isAdmin() ||
        // 2. A user can write to their own profile if one of the bootstrap/update conditions is met.
        (isOwner(userId) && (
          // 2a. BOOTSTRAP: Allow creation of the very first admin.
          // This is true on CREATE if `resource` is null and the incoming role is 'Admin'.
          (resource == null && request.resource.data.role == 'Admin') ||
          // 2b. UPDATE: Allow a user to update their own profile if they are NOT changing their role.
          (resource != null && request.resource.data.role == resource.data.role)
        ));

      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     */
    match /orders/{orderId} {
      allow read, write: if isAdmin();
    }
    
    /**
     * @description Global application settings, only accessible by admins.
     */
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      // Anyone can view the menu.
      allow get, list: if true;
      // Only admins can modify the menu.
      allow write: if isAdmin();

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
