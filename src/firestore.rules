
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // This check is safe because the `get` rule for a user's own profile is non-recursive.
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    function isParentOf(childId) {
      // Check if the requester is the parent of the document being accessed,
      // by looking at the childIds array in the requester's own document.
      let parentDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
             && 'childIds' in parentDoc
             && parentDoc.childIds.includes(childId);
    }
    
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }


    // --------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------

    match /users/{userId} {
      // READ: 
      // A user can get their own document.
      // An admin can get any document.
      // A parent can get the document of a user listed in their childIds.
      allow get: if isOwner(userId) || isAdmin() || isParentOf(userId);
      
      // LIST:
      // Only admins can list/query the entire users collection.
      // Parents will fetch their children via specific GETs (through an 'in' query), not a broad LIST.
      allow list: if isAdmin();
      
      // CREATE:
      // An admin can create any user.
      // A new user can create their own 'Admin' profile (for initial setup).
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == 'Admin');
      
      // UPDATE:
      // An admin can update any user.
      // A user can update their own profile as long as they are not changing their role.
      // This also allows a role to be set for the first time on a partially created document.
      allow update: if isAdmin() || (isOwner(userId) && (!('role' in resource.data) || request.resource.data.role == resource.data.role));

      // DELETE:
      // Only an admin can delete a user profile.
      allow delete: if isAdmin();


      /**
       * @description Manages a user's orders, nested under their profile.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isCreatingValidOrder(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Top-level orders collection, aggregated for the admin dashboard.
     */
    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global application settings.
     * Read access is given to any signed-in user to prevent race conditions on initial dashboard load.
     * Write access is restricted to admins.
     */
    match /settings/{settingId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Publicly viewable tuckshop menu items.
     */
    match /menuItems/{menuItemId} {
      // Anyone can view the menu.
      allow get, list: if true;
      // Only admins can modify the menu.
      allow write: if isAdmin();

      /**
       * @description Inventory is admin-only.
       */
      match /inventory/{inventoryId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
