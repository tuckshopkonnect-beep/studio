
/**
 * Core Philosophy: This ruleset enforces a hybrid security model. It provides public,
 * read-only access to shared data like the tuckshop menu (/menuItems), while
 * enforcing strict user ownership for all personal data, such as user profiles
 * (/users/{userId}) and their corresponding orders (/users/{userId}/orders).
 *
 * Data Structure: The data is organized into two main top-level collections:
 * - /menuItems: A public collection containing all available food and drink items.
 * - /users: A collection where each user's private data is stored under a
 *   document matching their unique user ID (UID). All user-specific subcollections,
 *   like 'orders', are nested under this path.
 *
 * Key Security Decisions:
 * - Admin-Managed Content: The menu (/menuItems) and inventory data are now managed
 *   by authenticated admins directly from the client. The rules ensure only users
 *   with the 'Admin' role can perform write operations.
 * - Strict Ownership: A user can only access the data tree located under their
 *   own user ID path (/users/{userId}/**). This prevents users from reading or
 *   writing another user's profile information or order history.
 * - No User Listing: To protect user privacy, listing the entire /users
 *   collection is disallowed for non-admins.
 * - Authorization Independence: User-specific documents (like Orders) contain a
 *   denormalized `userId` field. This allows rules to validate ownership directly
 *   from the document's data without needing costly or complex lookups, making
 *   the rules more performant and secure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership model.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a document currently exists in Firestore.
     * Crucial for protecting against writes to non-existent paths.
     */
    function isExistingDoc() {
      return resource != null;
    }
    
    /**
     * Checks if the currently authenticated user has the 'Admin' role.
     * It reads the user's profile from the /users collection.
     */
    function isAdmin() {
      // It is critical that we check for sign in first, otherwise this rule will
      // throw a null pointer exception if an unauthenticated user tries to access.
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    /**
     * A composite check for state-changing operations (update, delete), ensuring
     * the user is the owner AND the document actually exists.
     */
    function isOwnerOfExistingDoc(userId) {
      return isOwner(userId) && isExistingDoc();
    }
    
    /**
     * This function allows the very first user document to be created.
     * It is used to bootstrap the initial administrator account.
     * It ensures no other user documents exist.
     */
    function isCreatingFirstUser() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }


    /**
     * Validates a new user document on creation.
     * Ensures the creator is the owner and the document's internal `id` field
     * matches the user's auth UID for relational integrity.
     */
    function isCreatingValidUser(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }
    
    /**
     * Validates a user document on update.
     * Ensures the user is the owner and that the `id` field is immutable.
     */
    function isUpdatingValidUser(userId) {
      return isOwnerOfExistingDoc(userId) && request.resource.data.id == resource.data.id;
    }

    /**
     * Validates a new order document on creation.
     * Ensures the creator is the owner and the denormalized `userId` field
     * inside the document matches the owner's UID in the path.
     */
    function isCreatingValidOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    /**
     * Validates an order document on update.
     * Ensures the user is the owner and that the `userId` field is immutable.
     */
    function isUpdatingValidOrder(userId) {
      return isOwnerOfExistingDoc(userId) && request.resource.data.userId == resource.data.userId;
    }

    // --------------------------------------------------------------------
    // User Data Rules (/users)
    // --------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow A signed-in user (auth.uid='user123') can (create) or (update) their own profile document at /users/user123.
     * @deny A signed-in user (auth.uid='user123') cannot (get) or (update) another user's profile at /users/user456. Listing all users is also denied.
     * @principle Restricts access to a user's own data tree and ensures relational integrity on creation.
     */
    match /users/{userId} {
      // An authenticated user can read their own profile, or an admin can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow list only for admins. This is where the error occurs.
      allow list: if isAdmin();
      
      // Allow creation if it's the first user (and they are an Admin) or if an existing admin is creating a user.
      allow create: if isCreatingFirstUser() || (isAdmin() && isCreatingValidUser(userId));
      
      // Allow update if the user is the owner or an admin.
      allow update: if isUpdatingValidUser(userId) || isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Manages a user's orders.
       * @path /users/{userId}/orders/{orderId}
       * @allow A user (auth.uid='user123') can (create) a new order in their own subcollection at /users/user123/orders/{orderId}.
       * @deny A user (auth.uid='user123') cannot (list) orders from another user's path at /users/user456/orders.
       * @principle Enforces document ownership via path hierarchy for all reads and writes.
       */
      match /orders/{orderId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isCreatingValidOrder(userId);
        allow update: if isUpdatingValidOrder(userId) || isAdmin();
        allow delete: if isOwnerOfExistingDoc(userId) || isAdmin();

        /**
         * @description Manages the specific items within a user's order.
         * @path /users/{userId}/orders/{orderId}/orderItems/{orderItemId}
         * @allow A user (auth.uid='user123') can (get) or (create) an item within one of their own orders.
         * @deny A user (auth.uid='user123') cannot access order items at any path starting with /users/user456/**.
         * @principle Inherits ownership from the parent document path, providing secure, granular control.
         */
        match /orderItems/{orderItemId} {
          allow get: if isOwner(userId) || isAdmin();
          allow list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update: if isOwnerOfExistingDoc(userId) || isAdmin();
          allow delete: if isOwnerOfExistingDoc(userId) || isAdmin();
        }
      }
    }
    
    // --------------------------------------------------------------------
    // Aggregated & Public Data Rules 
    // --------------------------------------------------------------------

    /**
     * @description Top-level orders collection for admin dashboard.
     * @path /orders/{orderId}
     * @allow Any signed-in admin can read this collection.
     * @deny All client-side writes are denied. This should be written to by a backend function.
     */
    match /orders/{orderId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isCreatingValidOrder(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }


    /**
     * @description Manages the publicly viewable tuckshop menu items.
     * @path /menuItems/{menuItemId}
     * @allow Any user can read. Only admins can write.
     * @deny Any non-admin client cannot (create), (update), or (delete) a menu item.
     * @principle Provides public read access while reserving modification for trusted admins.
     */
    match /menuItems/{menuItemId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Manages inventory stock levels for menu items. THIS IS ADMIN-ONLY.
       * @path /menuItems/{menuItemId}/inventory/{inventoryId}
       * @allow No client is ever allowed to perform any operation on this path.
       * @deny A signed-in user cannot (get) the inventory document at /menuItems/burger123/inventory/stock.
       * @principle Enforces a "deny-all" policy for sensitive data that must only be managed by a secure backend environment (e.g., Cloud Functions with Admin SDK).
       */
      match /inventory/{inventoryId} {
        allow read: if isAdmin();
        allow write: if isAdmin();
      }
    }
  }
}

    